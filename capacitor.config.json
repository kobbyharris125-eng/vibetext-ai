{
  "appId":     "com.vibetext.ai",
  "appName":   "VibeText AI",
  "webDir":    "dist",
  "bundledWebRuntime": false,
  "android": {
    "allowMixedContent": false,
    "backgroundColor":   "#F8FAFC",
    "buildOptions": {
      "keystorePath":    "vibetext-release.keystore",
      "keystoreAlias":   "vibetext",
      "releaseType":     "AAB"
    }
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration":      2000,
      "launchAutoHide":          true,
      "backgroundColor":         "#0f172a",
      "androidSplashResourceName": "splash",
      "showSpinner":             false
    },
    "StatusBar": {
      "style":           "DARK",
      "backgroundColor": "#F8FAFC"
    },
    "Keyboard": {
      "resize":          "body",
      "style":           "DARK",
      "resizeOnFullScreen": true
    }
  },
  "server": {
    "androidScheme": "https",
    "cleartext":     false
  }
}
